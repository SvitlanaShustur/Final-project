      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1c184q11ppeqxz19jjun61ksorvy].[avg:Calculation_0001070589903149:qk]&quot;' value='Avg. Check (at a Discount)' />
          <alias key='&quot;[federated.1c184q11ppeqxz19jjun61ksorvy].[avg:Calculation_0001070592778542:qk]&quot;' value='Avg. Check (Full Price)' />
        </aliases>
      </column>
      <column caption='AVG_Revenue Female' datatype='real' name='[AVG_Revenue (copy)_0001071288852746]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF [Gender] = &apos;Female&apos; THEN [Net Amount] END )&#10;/&#10;COUNT( IF [Gender] = &apos;Female&apos; THEN [TID] END )' />
      </column>
      <column caption='AVG_Revenue Male' datatype='real' name='[AVG_Revenue Female (copy)_0001071289524491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF [Gender] = &apos;Male&apos; THEN [Net Amount] END )&#10;/&#10;COUNT( IF [Gender] = &apos;Male&apos; THEN [TID] END )' />
      </column>
      <column caption='AVG_Revenue Other' datatype='real' name='[AVG_Revenue Male (copy)_0001071289667852]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF [Gender] = &apos;Other&apos; THEN [Net Amount] END )&#10;/&#10;COUNT( IF [Gender] = &apos;Other&apos; THEN [TID] END )' />
      </column>
      <column datatype='string' name='[Age Group]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;60 and above&quot;' value='60 &lt;' />
          <alias key='&quot;under 18&quot;' value='0-18' />
        </aliases>
      </column>
      <column aggregation='Sum' datatype='integer' name='[CID]' role='dimension' type='ordinal' />
      <column caption='Period' datatype='datetime' name='[Calculation_0001070299865185]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &quot;Day&quot; THEN DATETRUNC(&apos;day&apos;, [Purchase Date])&#10;WHEN &quot;Week&quot; THEN DATETRUNC(&apos;week&apos;, [Purchase Date])&#10;WHEN &quot;Month&quot; THEN DATETRUNC(&apos;month&apos;, [Purchase Date])&#10;WHEN &quot;Quarter&quot; THEN DATETRUNC(&apos;quarter&apos;, [Purchase Date])&#10;WHEN &quot;Year&quot; THEN DATETRUNC(&apos;year&apos;, [Purchase Date])&#10;END' />
      </column>
      <column caption='Overall Trend' datatype='real' name='[Calculation_0001070313500770]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_0001070299865185] : SUM([Net Amount]) }' />
      </column>
      <column caption='Sum Order Net' datatype='real' hidden='true' name='[Calculation_0001070329450596]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [TID] : SUM([Net Amount]) }' />
      </column>
      <column caption='Order Discount Flag' datatype='string' name='[Calculation_0001070330204262]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [TID] :&#10;    IF MAX( IIF(ZN([Discount Amount (INR)]) &gt; 0 OR LOWER([Discount Availed])=&quot;yes&quot;, 1, 0) ) = 1&#10;    THEN &quot;Discount Applied&quot;&#10;    ELSE &quot;Full Price&quot;&#10;    END&#10;}' />
      </column>
      <column caption='Count TID' datatype='integer' name='[Calculation_0001070340128874]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([TID])' />
      </column>
      <column caption='Net Revenue (Discount Yes)' datatype='real' name='[Calculation_0001070589903149]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Discount Availed] = &quot;Yes&quot; THEN [Net Amount] END' />
      </column>
      <column caption='Net Revenue (Full Price)' datatype='real' name='[Calculation_0001070592778542]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Discount Availed] = &quot;No&quot; THEN [Net Amount] END' />
      </column>
      <column caption='Sales 2024' datatype='real' name='[Calculation_0001070654828878]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Purchase Date]) = 2024 THEN [Net Amount] END)' />
      </column>
      <column caption='Sales YOY lnc' datatype='string' name='[Calculation_0001070655885649]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF[Sales 2024 (copy)_0001070655508816] &gt; 0 THEN &apos;▲&apos; END' />
      </column>
      <column caption='Purchase' datatype='real' name='[Calculation_0001070715515250]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([TID]) / COUNT([CID])' />
      </column>
      <column caption='First Purchase Date' datatype='datetime' name='[Calculation_0001070716088691]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [CID] :&#10;    MIN(&#10;        IF [Purchase Date] &gt;= #2022-01-01# THEN [Purchase Date] END&#10;    )&#10;}' />
      </column>
      <column caption='Last Purchase Date' datatype='datetime' name='[Calculation_0001070716850548]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [CID] :&#10;    MAX(&#10;        IF [Purchase Date] &gt;= #2022-01-01# THEN [Purchase Date] END&#10;    )&#10;}' />
      </column>
      <column caption='Customer Lifetime' datatype='integer' name='[Calculation_0001070717079925]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_0001070716088691],[Calculation_0001070716850548])' />
      </column>
      <column caption='Country' datatype='string' name='[Calculation_0001070946697406]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='&quot;India&quot;' />
      </column>
      <column caption='Avg_net_Revenue(Discount)' datatype='real' name='[Calculation_0001070992712172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0001070589903149])' />
      </column>
      <column caption='Avg_net_Revenue(Full)' datatype='real' name='[Calculation_0001070992921069]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0001070592778542])' />
      </column>
      <column caption='%_Discount_Purchase' datatype='real' name='[Calculation_0001071264895230]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Discount Amount (INR)])/SUM([Net Amount]) * 100' />
      </column>
      <column caption='AVG_Revenue' datatype='real' name='[Calculation_0001071284662530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Net Amount]) /COUNT([TID])' />
      </column>
      <column caption='Net Revenue_Female' datatype='real' name='[Calculation_0001071286792451]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Gender] = &quot;Female&quot; THEN [Net Amount] END' />
      </column>
      <column caption='Gender_P' datatype='boolean' name='[Calculation_0001071297954067]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#10;WHEN &quot;All&quot; THEN TRUE&#10;WHEN &quot;Female&quot; THEN [Gender] = &quot;Female&quot;&#10;WHEN &quot;Male&quot; THEN [Gender] = &quot;Male&quot;&#10;WHEN &quot;Other&quot; THEN [Gender] = &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Revenue_Gender' datatype='real' name='[Calculation_0001071301820692]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;All&quot; THEN SUM([Net Amount])&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Female&quot; THEN SUM( IF [Gender] = &quot;Female&quot; THEN [Net Amount] END )&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Male&quot; THEN SUM( IF [Gender] = &quot;Male&quot; THEN [Net Amount] END )&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Other&quot; THEN SUM( IF [Gender] = &quot;Other&quot; THEN [Net Amount] END )&#10;END' />
      </column>
      <column caption='Avg_Revenue_Gender' datatype='real' name='[Calculation_0001071307784473]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;All&quot; THEN&#10;    SUM([Net Amount]) / COUNTD([TID])&#10;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Female&quot; THEN&#10;    SUM( IF [Gender] = &quot;Female&quot; THEN [Net Amount] END )&#10;    / COUNTD( IF [Gender] = &quot;Female&quot; THEN [TID] END )&#10;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Male&quot; THEN&#10;    SUM( IF [Gender] = &quot;Male&quot; THEN [Net Amount] END )&#10;    / COUNTD( IF [Gender] = &quot;Male&quot; THEN [TID] END )&#10;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Other&quot; THEN&#10;    SUM( IF [Gender] = &quot;Other&quot; THEN [Net Amount] END )&#10;    / COUNTD( IF [Gender] = &quot;Other&quot; THEN [TID] END )&#10;END' />
      </column>
      <column caption='Renenue_2022_2024' datatype='real' name='[Calculation_2212809126965248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Purchase Date] &gt;= DATE(&quot;2022-01-01&quot;)&#13;&#10;AND [Purchase Date] &lt;= DATE(&quot;2024-09-18&quot;)&#13;&#10;THEN [Net Amount]&#13;&#10;END' />
      </column>
      <column caption='Customer per cohort' datatype='integer' name='[Calculation_2912373335248899]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED  DATETRUNC(&apos;quarter&apos;, [Calculation_0001070716088691]): COUNTD([CID])}' />
      </column>
      <column caption='Retation' datatype='real' name='[Calculation_2912373335490564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CID]) / SUM([Calculation_2912373335248899])' />
      </column>
      <column caption='Quarters  elapsed' datatype='integer' name='[Calculation_2912373335715845]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;quarter&apos;, DATETRUNC(&apos;quarter&apos;,[Calculation_0001070716088691]), DATETRUNC(&apos;quarter&apos;, [Purchase Date]))' />
      </column>
      <column caption='Coun YOY CID lnc' datatype='string' name='[Coun YOY TID lnc (copy)_0001070721290620]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF[Count YOY (copy)_0001070720569722] &gt; 0 THEN &quot;▲&quot; END' />
      </column>
      <column caption='Count YOY CID' datatype='real' name='[Count YOY (copy)_0001070720569722]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNTD(IF YEAR([Purchase Date]) = 2024 THEN [CID] END)&#10;- COUNTD(IF YEAR([Purchase Date]) = 2023 THEN [CID] END)) / &#10;COUNTD(IF YEAR([Purchase Date]) = 2023 THEN [CID] END)' />
      </column>
      <column caption='Count YOY  CID Dec' datatype='string' name='[Count YOY Dec (copy)_0001070720852347]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF[Count YOY (copy)_0001070720569722] &lt; 0 THEN &quot;▼&quot; END' />
