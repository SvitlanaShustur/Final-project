              <calculation class='tableau' formula='(COUNTD(IF YEAR([Purchase Date]) = 2024 THEN [CID] END)&#10;- COUNTD(IF YEAR([Purchase Date]) = 2023 THEN [CID] END)) / &#10;COUNTD(IF YEAR([Purchase Date]) = 2023 THEN [CID] END)' />
