      <repository-location id='Revenue_Gender_Category' path='/workbooks/E-commerce_17712497750510' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='project1_df' name='federated.1c184q11ppeqxz19jjun61ksorvy' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='All' caption='Top N Category' datatype='integer' datatype-customized='true' name='[Parameter 2]' param-domain-type='list' role='measure' type='quantitative' value='9'>
              <calculation class='tableau' formula='9' />
              <aliases>
                <alias key='3' value='TOP 3' />
                <alias key='5' value='TOP 5' />
                <alias key='9' value='All' />
              </aliases>
            </column>
            <column caption='Gender' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;All&quot;'>
              <calculation class='tableau' formula='&quot;All&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1c184q11ppeqxz19jjun61ksorvy'>
            <column datatype='string' name='[Age Group]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;60 and above&quot;' value='60 &lt;' />
                <alias key='&quot;under 18&quot;' value='0-18' />
              </aliases>
            </column>
            <column aggregation='Sum' datatype='integer' name='[CID]' role='dimension' type='ordinal' />
            <column caption='Net Revenue (Discount Yes)' datatype='real' name='[Calculation_0001070589903149]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Discount Availed] = &quot;Yes&quot; THEN [Net Amount] END' />
            </column>
            <column caption='Net Revenue (Full Price)' datatype='real' name='[Calculation_0001070592778542]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Discount Availed] = &quot;No&quot; THEN [Net Amount] END' />
            </column>
            <column caption='First Purchase Date' datatype='datetime' name='[Calculation_0001070716088691]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{ FIXED [CID] :&#10;    MIN(&#10;        IF [Purchase Date] &gt;= #2022-01-01# THEN [Purchase Date] END&#10;    )&#10;}' />
            </column>
            <column caption='Last Purchase Date' datatype='datetime' name='[Calculation_0001070716850548]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{ FIXED [CID] :&#10;    MAX(&#10;        IF [Purchase Date] &gt;= #2022-01-01# THEN [Purchase Date] END&#10;    )&#10;}' />
            </column>
            <column caption='Customer Lifetime' datatype='integer' name='[Calculation_0001070717079925]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_0001070716088691],[Calculation_0001070716850548])' />
            </column>
            <column caption='Avg_net_Revenue(Discount)' datatype='real' name='[Calculation_0001070992712172]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_0001070589903149])' />
